<%= render layout: 'layouts/phone_head' do %>
  <div class="as-bar">
    <%= link_to '/', class: 'px-4' do %>
      <%= svg_tag 'angle-left', kind: 'regular' %>
    <% end %>
    <div class="bar-title"></div>
    <i class="px-5"></i>
  </div>
  <main id="weui-tab__panel">
    <%= yield %>
  </main>
  <div class="buttons as-bottom">
    <%= link_to({ controller: 'org/board/organs', action: 'new' }, class: 'button is-fullwidth is-primary') do %>
      <%= svg_tag 'plus' %>
      <span><%= t('org.board.organs.new.title') %></span>
    <% end %>
  </div>
<% end %>
