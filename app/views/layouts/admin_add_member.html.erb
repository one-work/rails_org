<%= render layout: 'layouts/admin_head' do %>
  <main class="columns as-main">
    <div class="column is-narrow p-0 has-page">
      <%= render 'admin/nav' %>
      <%= render 'admin/menu_bar' %>
    </div>
    <turbo-frame id="panel" refresh="morph" data-turbo-action="advance" class="column as-body">
      <ul class="breadcrumb has-succeeds-separator ml-3"><%= render 'breadcrumb' %></ul>
      <%= render 'alert' %>
      <div class="box has-page-centered radius-bottom-none">
        <div style="width: 500px">
          <%= yield %>
        </div>
      </div>
    </turbo-frame>
  </main>
<% end %>
