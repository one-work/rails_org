<div class="card as-transparent">
  <div class="card-header">
    <span class="size-7 text-grey has-border-left-primary"><%= t('org.admin.title') %></span>
  </div>
  <div class="card-content fixed-grid has-4-cols">
    <div class="grid">
      <%= link_to({ controller: 'org/admin/members' }, class: 'cell has-column-centered') do %>
        <%= svg_tag 'user-gear', class: 'icon is-medium text-primary' %>
        <div class="text-grey size-7 mt-1"><%= t('org.admin.members.index.title') %></div>
      <% end %>
      <%= link_to({ controller: 'org/admin/departments' }, class: 'cell has-column-centered') do %>
        <%= svg_tag 'chalkboard-user', class: 'icon is-medium text-primary' %>
        <div class="text-dark size-7 mt-1"><%= t('org.admin.departments.index.title') %></div>
      <% end %>
    </div>
  </div>
</div>
