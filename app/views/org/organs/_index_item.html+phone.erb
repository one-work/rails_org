<div>
  <strong><%= model.name %></strong>
  <div class="tags has-addons display-inline-flex">
    <span class="tag">营业时间</span>
    <% if model.start_at %>
      <span class="tag"><%= model.start_at.to_fs(:time) %></span>
    <% else %>
      <span class="tag">09:00</span>
    <% end %>
  </div>
</div>
<% if model.address.present? %>
  <p class="size-7">
    <%= svg_tag 'location-dot', class: 'icon is-small text-grey' %>
    <span><%= model.address_short.presence || model.address %></span>
  </p>
  <p>
  <% if model.distance.presence %>
    <span><%= model.distance %></span>
  <% end %>
  </p>
<% end %>
