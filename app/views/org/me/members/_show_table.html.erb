<div>
  <dt><%= Org::Member.human_attribute_name(:avatar) %></dt>
  <dd><%= image_tag @member.avatar, class: 'image is-64x64' if @member.avatar.attached? %></dd>
</div>
<div>
  <dt><%= Org::Member.human_attribute_name(:name) %></dt>
  <dd>
    <%= text_field_tag 'member[name]', @member.name, class: 'input', form: 'show-form', data: { single_input_target: 'input' } %>
  </dd>
</div>
<div>
  <dt><%= Org::Member.human_attribute_name(:identity) %></dt>
  <dd><%= @member.identity %></dd>
</div>
<div>
  <dt><%= Org::Member.human_attribute_name(:join_on) %></dt>
  <dd><%= @member.join_on %></dd>
</div>
<div>
  <dt><%= Org::Member.human_attribute_name(:auth_token) %></dt>
  <dd class="text-left is-wrap">
    <div data-controller="clipboard">
      <span data-clipboard-target="source" class="family-monospace"><%= @member.auth_token %></span>
      <span data-action="click->clipboard#copy" class="tag is-badge is-danger">复制</span>
      <div data-clipboard-target="toast" class="tag is-badge is-success display-none">
        <%= svg_tag 'check' %>
      </div>
    </div>
  </dd>
</div>
<% if @member.departments.present? %>
<div>
  <dt><%= Org::Member.human_attribute_name(:department_id) %></dt>
  <dd>
    <% @member.departments.each do |department| %>
      <p><%= department.full_name %></p>
    <% end %>
  </dd>
</div>
<% end %>
