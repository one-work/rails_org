<% if defined?(url) %>
  <%= turbo_stream.apend_body partial: 'visit', locals: { url: url } %>
<% elsif params[:redirect_state].present? %>
  <%= turbo_stream.apend_body partial: 'visit', locals: { url: url_for(**StateUtil.decode(params[:redirect_state])) } %>
<% else %>
  <%= turbo_stream.apend_body partial: 'visit', locals: { url: url_for(controller: 'org/board/organs') } %>
<% end %>
