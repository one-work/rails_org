<div id="buttons" class="buttons as-bottom">
  <% if current_member.admin? %>
    <div class="">
      <p>注意：</p>
      <p>此操作将删除本团队及本团队的所有数据，且不可逆，请务必谨慎操作！</p>
    </div>
    <%= button_to({ action: 'destroy' }, method: :delete, data: { turbo_confirm: t('.destroy.confirm') }, class: 'button is-danger') do %>
      <%= svg_tag 'trash' %>
      <span><%= t('.destroy.title') %></span>
    <% end %>
  <% end %>
</div>
