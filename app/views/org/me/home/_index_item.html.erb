<%= link_to({ controller: 'org/me/members', action: 'show' }, class: 'media') do %>
  <div class="media-content">
    <%= svg_tag 'user-gear' %>
    <span><%= t('.members.show.title') %></span>
  </div>
  <div class="media-right">
    <%= svg_tag 'chevron-right' %>
  </div>
<% end %>
<% if request.variant.include?(:mini_program) %>
  <div
    data-controller="mini-program"
    data-mini-program-nav-value="true"
    data-mini-program-url-value="/pages/mobile/index"
    data-mini-program-data-value="<%= { url: url_for(controller: 'wechat/program_users', action: 'mobile', auth_token: Current.session.once_token, only_path: false) }.to_json %>"
    data-action="click->mini-program#navTo"
    class="media"
  >
    <div class="media-content">
      <%= svg_tag 'mobile' %>
      <span>绑定手机号</span>
    </div>
    <div class="media-right">
      <%= svg_tag 'chevron-right' %>
    </div>
  </div>
<% end %>
