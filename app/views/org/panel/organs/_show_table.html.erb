<div>
  <dt><%= Org::Organ.human_attribute_name(:name) %></dt>
  <dd><%= @organ.name %></dd>
</div>
<div>
  <dt><%= Org::Organ.human_attribute_name(:logo) %></dt>
  <dd><%= image_tag @organ.logo.url, class: 'image' if @organ.logo.attached? %></dd>
</div>
<div>
  <dt><%= Org::Organ.human_attribute_name(:name_short) %></dt>
  <dd><%= @organ.name_short %></dd>
</div>
<div>
  <dt><%= Org::Organ.human_attribute_name(:area_id) %></dt>
  <dd><%= @organ.area&.full_name %></dd>
</div>
<div>
  <dt><%= Org::Organ.human_attribute_name(:license) %></dt>
  <dd><%= @organ.license %></dd>
</div>
<div>
  <dt><%= Org::Organ.human_attribute_name(:geo) %></dt>
  <dd><%= @organ.geo %></dd>
</div>
<div>
  <dt><%= Org::Organ.human_attribute_name(:address) %></dt>
  <dd><%= @organ.address %></dd>
</div>
<div>
  <dt></dt>
  <dd>
    <%= image_tag @scene.qrcode_data_url, class: 'image' if @scene %>
  </dd>
</div>
