<%= button_to({ action: 'destroy' }, method: :delete, form: { data: { turbo_confirm: t('.destroy.confirm') } }, class: 'cell has-column-centered') do %>
  <%= svg_tag 'trash' %>
  <span><%= t('.destroy.title') %></span>
<% end %>
<%= button_to({ action: 'edit' }, class: 'cell has-column-centered') do %>
  <%= svg_tag 'pencil' %>
  <span><%= t('.edit.title') %></span>
<% end %>
<%= button_to({ action: 'show' }, class: 'cell has-column-centered') do %>
  <%= svg_tag 'circle-info' %>
  <span><%= t('.show.title') %></span>
<% end %>
<%= button_to({ action: 'invite' }, class: 'cell has-column-centered') do %>
  <%= svg_tag 'user-plus' %>
  <span><%= t('.invite.title') %></span>
<% end %>
