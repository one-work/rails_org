<%= form_with model: @organ, url: { action: 'update' } do |f| %>
  <%= render 'error_messages', target: @organ %>
  <%= f.text_field :name, required: true %>
  <%= f.text_field :name_short %>
  <%= render partial: 'com/attachments/list_field', locals: { target: f.object.logo, f: f } %>
  <%= render partial: 'com/nodes/outer_select', locals: { f: f, node: @organ.area, outer: 'area' } %>
  <%= f.text_area :address %>
  <%= f.time_zone_select :timezone %>
  <%= f.select :locale, options_for_select(User.options_i18n(:locale), @organ.locale) %>
  <%= f.submit %>
<% end %>
